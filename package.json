{
  "name": "gigbuddy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n api,web -c blue,green \"npm:server:dev\" \"npm:dev\"",
    "build": "vite build",
    "build:all": "vite build && concurrently -n api,web -c blue,green \"npm:server\" \"npm:preview\"",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:dev": "nodemon server/index.js",
    "server:debug": "nodemon --inspect-brk server/index.js",
    "migrate": "node server/db/migrate.js",
    "migrate:integration-secrets": "node server/scripts/migrateIntegrationSecrets.js",
    "test": "vitest --exclude src/tests/server",
    "test:server": "vitest run --no-file-parallelism src/tests/server",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --exclude src/tests/server --coverage",
    "coverage:server": "vitest run --no-file-parallelism src/tests/server --coverage --config vitest.server.config.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/bebas-neue": "^5.2.5",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/montserrat": "^5.2.8",
    "@material/web": "^2.4.1",
    "@mollie/api-client": "^4.5.0",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@mui/x-charts": "^9.4.0",
    "@mui/x-date-pickers": "^9.0.2",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "abcjs": "^6.6.3",
    "browser-image-compression": "^2.0.2",
    "chordsheetjs": "^15.5.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "i18next": "^26.3.2",
    "i18next-browser-languagedetector": "^8.2.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "openid-client": "^6.8.3",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.8",
    "react-image-crop": "^11.0.10",
    "react-leaflet": "^5.0.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.14.1",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "archiver": "^8.0.0",
    "unzipper": "^0.12.5",
    "fast-csv": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
