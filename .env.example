PGHOST=localhost
PGDATABASE=gigbuddy
PGUSER=your_pg_user
PGPASSWORD=your_pg_password
PGPORT=5432
SERVER_PORT=3002
CLIENT_ORIGIN=http://localhost:5173
# debug | info | warn | error — defaults to info when unset or unrecognized.
LOG_LEVEL=info

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3002/api/auth/callback

# Personal Microsoft Account sign-in (Entra app registration, "Personal
# Microsoft accounts only"). Optional — Microsoft sign-in is disabled when unset.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:3002/api/auth/callback/microsoft
SESSION_SECRET=change-me-to-a-long-random-string
APP_URL=http://localhost:5173
ADMIN_EMAIL=your email

# Mollie payment integration (optional)
# MOLLIE_WEBHOOK_BASE_URL defaults to APP_URL when unset.
# In dev, set this to a public tunnel URL so Mollie can reach your local server.
MOLLIE_WEBHOOK_BASE_URL=
# Set true only for local/testing flows where Mollie cannot reach the webhook URL.
MOLLIE_DISABLE_WEBHOOK=false

# Link-page integration (the decoupled linkpage/ app). Optional — the
# "Edit link page" affordance stays hidden while unset. LINKPAGE_SECRET is the
# shared HMAC secret (same value in the linkpage app's GIGBUDDY_SYNC_SECRET);
# LINKPAGE_URL is the public origin of the linkpage app (e.g. https://link.example.com).
LINKPAGE_SECRET=
LINKPAGE_URL=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@gigbuddy.app

# RustFS object storage (S3-compatible)
# Outside Docker (npm run dev:all): RUSTFS_ENDPOINT=localhost
# Inside Docker Compose: app service overrides RUSTFS_ENDPOINT=rustfs automatically
RUSTFS_ENDPOINT=localhost
RUSTFS_PORT=9000
RUSTFS_USE_SSL=false
RUSTFS_ACCESS_KEY=accesskey
RUSTFS_SECRET_KEY=secretkey
RUSTFS_BUCKET=gigbuddy

# Required at API startup. JSON maps key IDs to base64-encoded 32-byte AES keys.
# Keep recovery copies outside the application secret store.
INTEGRATION_SECRETS_KEYS=
INTEGRATION_SECRETS_ACTIVE_KEY_ID=

# Grafana Cloud observability (only used by the `alloy` compose service, which
# runs under the `observability` profile — not started by local dev). See
# observability/README.md. GCLOUD_RW_API_KEY is the only secret; the access
# policy behind it needs scopes: metrics:write, logs:write.
GCLOUD_HOSTED_METRICS_URL=
GCLOUD_HOSTED_METRICS_ID=
GCLOUD_HOSTED_LOGS_URL=
GCLOUD_HOSTED_LOGS_ID=
GCLOUD_RW_API_KEY=
GCLOUD_SCRAPE_INTERVAL=60s
