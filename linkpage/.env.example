# Copy to .env for local development (server/index.js loads it via dotenv).
# In production inject these through your secret manager instead.

# HTTP port of the linkpage API/server.
LINKPAGE_PORT=3010

# Postgres connection. Either a full URL...
#LINKPAGE_DATABASE_URL=postgres://user:pass@localhost:5432/gigbuddy_linkpage
# ...or standard PG* environment variables (PGHOST/PGUSER/PGPASSWORD/PGPORT are
# read by the pg driver as usual) with the database name below. Statistics and
# page layouts live in this dedicated database, NEVER in gigbuddy's.
LINKPAGE_PGDATABASE=gigbuddy_linkpage

# Origin of the GigBuddy API this app syncs content from.
GIGBUDDY_URL=http://localhost:3002

# Shared HMAC secret — must equal LINKPAGE_SECRET in the GigBuddy deployment.
# Used to verify editor handoff tokens, sign editor sessions, and authenticate
# the server-to-server content export pull.
GIGBUDDY_SYNC_SECRET=

# Public origin of this app (used in absolute URLs shown to editors).
LINKPAGE_PUBLIC_URL=http://localhost:5174

# Minutes before a page's synced content snapshot is considered stale and
# refreshed in the background on public views (keeps gig listings current).
LINKPAGE_CONTENT_TTL_MINUTES=15

# Privacy controls for visit statistics (see PRIVACY.md).
# Statistics live in a rolling window: each page keeps its band's plan window
# (30 days, or 90 on gold — synced from GigBuddy) with this value as the
# fallback for pages without plan data. Hard-capped at 90 days.
STATS_RETENTION_DAYS=30
# Set to 1 to disable all visit statistics collection.
STATS_DISABLED=
