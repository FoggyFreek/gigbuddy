{
  "name": "gigbuddy-linkpage",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone public link page (widget stack) for GigBuddy bands, with privacy-first visit statistics.",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm:server:dev\" \"npm:web:dev\"",
    "web:dev": "vite",
    "server": "node server/index.js",
    "server:dev": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "migrate": "node server/migrate.js",
    "stats:purge": "node server/purgeStats.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ipaddr.js": "^2.4.0",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "supertest": "^7.2.2",
    "vite": "^8.0.4",
    "vitest": "^4.1.4"
  }
}
